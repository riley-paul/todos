{
  "name": "astro-test",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "npm-run-all --parallel dev:db dev:server",
    "build": "astro check && astro build --remote",
    "preview": "astro build && wrangler pages dev --port 4321",
    "test": "vitest --no-file-parallelism",
    "dev:db": "turso dev --db-file dev.db",
    "dev:server": "astro dev --host",
    "cf-typegen": "wrangler types",
    "db:push": "drizzle-kit push",
    "db:push:prod": "NODE_ENV=production drizzle-kit push",
    "db:push:test": "NODE_ENV=test drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:studio:prod": "NODE_ENV=production drizzle-kit studio",
    "db:studio:test": "NODE_ENV=test drizzle-kit studio",
    "db:seed": "tsx src/db/seed.ts",
    "db:seed:test": "NODE_ENV=test tsx src/db/seed.ts"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/cloudflare": "^12.6.13",
    "@astrojs/react": "^4.4.2",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@faker-js/faker": "^9.9.0",
    "@hookform/resolvers": "^5.2.2",
    "@libsql/client": "^0.14.0",
    "@node-rs/argon2": "^1.8.3",
    "@radix-ui/themes": "^3.3.0",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/db": "^0.5.33",
    "@tanstack/query-core": "^5.90.20",
    "@tanstack/query-db-collection": "^1.0.33",
    "@tanstack/react-db": "^0.1.80",
    "@tanstack/react-query": "^5.96.2",
    "@tanstack/react-router": "^1.168.10",
    "@tanstack/react-router-devtools": "^1.133.32",
    "@tanstack/router-plugin": "^1.167.12",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "ably": "^2.21.0",
    "arctic": "^3.7.0",
    "astro": "^5.18.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dotenv": "^16.6.1",
    "dotenv-expand": "^12.0.3",
    "drizzle-kit": "^0.30.6",
    "drizzle-orm": "^0.40.1",
    "drizzle-zod": "^0.7.1",
    "jotai": "^2.19.0",
    "lucide-react": "^0.525.0",
    "radix-themes-tw": "^1.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.72.1",
    "sonner": "^1.7.4",
    "tailwind-merge": "^2.6.1",
    "tailwindcss": "^4.1.13",
    "tiny-invariant": "^1.3.3",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "usehooks-ts": "^3.1.1",
    "vite-plugin-pwa": "^0.20.5",
    "vitest": "^3.2.4"
  },
  "devDependencies": {
    "@tanstack/router-devtools": "^1.166.11",
    "@types/node": "^20.19.39",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "wrangler": "^4.80.0"
  },
  "overrides": {
    "vite": "6.0.2"
  }
}
