{
  "name": "astro-test",
  "type": "module",
  "version": "1.0.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "npm-run-all --parallel dev:db dev:server",
    "build": "astro check && astro build --remote",
    "preview": "astro build && wrangler pages dev --port 4321",
    "test": "vitest --no-file-parallelism",
    "dev:db": "turso dev --db-file dev.db",
    "dev:server": "astro dev --host",
    "cf-typegen": "wrangler types",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/cloudflare": "^13.1.10",
    "@astrojs/react": "^5.0.3",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@faker-js/faker": "^9.9.0",
    "@hono/zod-validator": "^0.7.6",
    "@hookform/resolvers": "^5.2.2",
    "@libsql/client": "^0.14.0",
    "@node-rs/argon2": "^1.8.3",
    "@radix-ui/themes": "^3.3.0",
    "@tailwindcss/vite": "^4.2.3",
    "@tanstack/react-hotkeys": "^0.9.1",
    "@tanstack/react-query": "^5.99.2",
    "@tanstack/react-router": "^1.168.23",
    "@tanstack/react-router-devtools": "^1.133.32",
    "@tanstack/router-plugin": "^1.167.22",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "ably": "^2.21.0",
    "arctic": "^3.7.0",
    "astro": "^6.1.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dotenv": "^16.6.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "hono": "^4.12.14",
    "jotai": "^2.19.1",
    "lucide-react": "^1.8.0",
    "radix-themes-tw": "^1.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.73.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.13",
    "tiny-invariant": "^1.3.3",
    "tw-animate-css": "^1.4.0",
    "usehooks-ts": "^3.1.1",
    "workbox-window": "^7.4.0"
  },
  "devDependencies": {
    "@tanstack/router-devtools": "^1.166.13",
    "@types/node": "^20.19.39",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "vitest": "^4.1.4",
    "wrangler": "^4.25.0"
  },
  "overrides": {
    "vite": "^7"
  }
}
