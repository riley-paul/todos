{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "types": [
      "vite-plugin-pwa/react",
      "vite-plugin-pwa/client",
      "vite-plugin-pwa/info"
    ],
    "noUnusedLocals": true,
    "moduleResolution": "bundler"
  },
  "exclude": ["node_modules", "dist"]
}
